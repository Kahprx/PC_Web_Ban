NODE_ENV=development
PORT=4000

FRONTEND_URL=http://localhost:5173

# Option A: one-line connection string (recommended)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/QuanLyPc

# Option B: separate fields (used when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=QuanLyPc
DB_USER=postgres
DB_PASSWORD=postgres

JWT_SECRET=super_secret_key
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Gmail SMTP (forgot password / contact)
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
# EMAIL_USER phai la dung tai khoan Gmail da tao app password ben duoi
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-without-spaces
EMAIL_FROM=KAH Gaming Store <your-email@gmail.com>
EMAIL_CONNECTION_TIMEOUT=15000
EMAIL_GREETING_TIMEOUT=15000
EMAIL_SOCKET_TIMEOUT=20000
SUPPORT_EMAIL=support@kahgaming.vn
